<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apartment Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-in { animation: fadeIn 0.3s ease-out forwards; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800">
<div id="root"></div>

<script type="text/babel">
    const { useState, useEffect, useRef } = React;

    const Icons = {
        Layout: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="7" height="9" x="3" y="3" rx="1" /><rect width="7" height="5" x="14" y="3" rx="1" /><rect width="7" height="9" x="14" y="12" rx="1" /><rect width="7" height="5" x="3" y="16" rx="1" /></svg>,
        Search: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>,
        Home: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>,
        Plus: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10" /><path d="M8 12h8" /><path d="M12 8v8" /></svg>,
        Image: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2" /><circle cx="9" cy="9" r="2" /><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" /></svg>,
        File: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" /><polyline points="14 2 14 8 20 8" /></svg>,
        Trash: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /></svg>,
        Lock: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>,
        Wrench: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>,
        TrendingUp: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>,
        CheckCircle: ({ size = 20 }) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    };

    const App = () => {
        const [currentUser, setCurrentUser] = useState(() => {
            const savedUser = sessionStorage.getItem('activeUser');
            return savedUser ? JSON.parse(savedUser) : null;
        });

        const [isAuthenticated, setIsAuthenticated] = useState(() => {
            return sessionStorage.getItem('isAuthSession') === 'true';
        });

        // Initialize state as empty array, we will fetch from Spring Boot
        const [apartments, setApartments] = useState([]);

        const [newAptName, setNewAptName] = useState('');
        const [selectedId, setSelectedId] = useState(null);
        const [searchTerm, setSearchTerm] = useState('');
        const [form, setForm] = useState({ title: '', price: '', productImage: '', invoiceImage: '', notes: '', tarih: '', status: 'Todo' });

        const idleTimeoutRef = useRef(null);
        const IDLE_TIME_LIMIT = 10 * 60 * 1000;

        const handleLogout = () => {
            setIsAuthenticated(false);
            setCurrentUser(null);
            sessionStorage.removeItem('isAuthSession');
            sessionStorage.removeItem('activeUser');
            if (idleTimeoutRef.current) clearTimeout(idleTimeoutRef.current);
        };

        // Spring Boot / PostgreSQL Integration: Fetch data on load
        useEffect(() => {
            if (isAuthenticated) {
                sessionStorage.setItem('isAuthSession', 'true');
                sessionStorage.setItem('activeUser', JSON.stringify(currentUser));

                // Fetch from Backend
                fetch('/api/apartments')
                    .then(res => {
                        if (res.ok) return res.json();
                        console.warn("Backend not running yet, using empty array.");
                        return [];
                    })
                    .then(data => setApartments(data))
                    .catch(err => console.error("Error fetching data:", err));
            } else {
                sessionStorage.removeItem('isAuthSession');
                sessionStorage.removeItem('activeUser');
            }
        }, [isAuthenticated, currentUser]);

        useEffect(() => {
            if (!isAuthenticated) return;
            const resetIdleTimer = () => {
                if (idleTimeoutRef.current) clearTimeout(idleTimeoutRef.current);
                idleTimeoutRef.current = setTimeout(() => {
                    alert('Session expired for your security.');
                    handleLogout();
                }, IDLE_TIME_LIMIT);
            };
            const events = ['mousemove', 'mousedown', 'keypress', 'scroll', 'touchstart'];
            events.forEach(e => window.addEventListener(e, resetIdleTimer));
            resetIdleTimer();
            return () => {
                if (idleTimeoutRef.current) clearTimeout(idleTimeoutRef.current);
                events.forEach(e => window.removeEventListener(e, resetIdleTimer));
            };
        }, [isAuthenticated]);

        // Helper function to sync updates to Spring Boot Backend
        const syncApartmentToBackend = (apartmentToSync) => {
            fetch('/api/apartments', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(apartmentToSync)
            }).catch(err => console.error("Failed to sync to backend", err));
        };

        const handleGoogleLogin = () => {
            const mockGoogleUser = {
                name: "Admin Manager",
                email: "admin@apartmentmanager.com",
                avatar: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&auto=format&fit=crop&q=80"
            };
            setCurrentUser(mockGoogleUser);
            setIsAuthenticated(true);
            setSelectedId(null);
        };

        const handleAddApartment = (e) => {
            e.preventDefault();
            const name = newAptName.trim();
            if (!name) return;
            if (apartments.some(apt => apt.id.toLowerCase() === name.toLowerCase())) {
                alert('This apartment already exists!');
                return;
            }

            const newApt = { id: name, items: [] };

            // Sync to backend, then update UI state
            fetch('/api/apartments', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(newApt)
            }).then(() => {
                setApartments(prev => [...prev, newApt]);
                setNewAptName('');
                setSelectedId(name);
            }).catch(err => {
                console.error(err);
                alert("Failed to save to database. Make sure backend is running.");
            });
        };

        const deleteApartment = (id, e) => {
            e.stopPropagation();
            if (window.confirm(`Are you sure you want to delete empty apartment "${id}"?`)) {
                // Delete from backend
                fetch(`/api/apartments/${id}`, { method: 'DELETE' })
                .then(() => {
                    setApartments(prev => prev.filter(apt => apt.id !== id));
                    if (selectedId === id) setSelectedId(null);
                }).catch(err => console.error("Failed to delete", err));
            }
        };

        const handleFile = (e, key) => {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (event) => {
                setForm(prev => ({ ...prev, [key]: event.target.result }));
            };
            reader.readAsDataURL(file);
        };

        const saveItem = () => {
            if (!form.title || !form.price) {
                alert("Please enter an item fix/product name and price.");
                return;
            }
            const texasDateTime = new Intl.DateTimeFormat('en-US', {
                timeZone: 'America/Chicago', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit'
            }).format(new Date());

            const newItem = { ...form, id: Date.now(), date: form.tarih || texasDateTime };

            const updatedApartments = apartments.map(apt => {
                if (apt.id === selectedId) {
                    const updatedApt = { ...apt, items: [newItem, ...apt.items] };
                    syncApartmentToBackend(updatedApt); // Send update to backend
                    return updatedApt;
                }
                return apt;
            });

            setApartments(updatedApartments);
            setForm({ title: '', price: '', productImage: '', invoiceImage: '', notes: '', tarih: '', status: 'Todo' });
        };

        const updateItemStatus = (itemId, newStatus) => {
            const updatedApartments = apartments.map(apt => {
                if (apt.id === selectedId) {
                    const updatedApt = {
                        ...apt,
                        items: apt.items.map(item => item.id === itemId ? { ...item, status: newStatus } : item)
                    };
                    syncApartmentToBackend(updatedApt); // Sync to backend
                    return updatedApt;
                }
                return apt;
            });
            setApartments(updatedApartments);
        };

        const deleteItem = (id) => {
            if (window.confirm('Are you sure you want to delete this record?')) {
                const updatedApartments = apartments.map(apt => {
                    if (apt.id === selectedId) {
                        const updatedApt = { ...apt, items: apt.items.filter(i => i.id !== id) };
                        syncApartmentToBackend(updatedApt); // Sync to backend
                        return updatedApt;
                    }
                    return apt;
                });
                setApartments(updatedApartments);
            }
        };

        const totalApartments = apartments.length;
        const grandTotalExpenses = apartments.reduce((acc, apt) => acc + apt.items.reduce((sum, item) => sum + (Number(item.price) || 0), 0), 0);

        const totalActiveTasks = apartments.reduce((acc, apt) =>
            acc + apt.items.filter(i => i.status === 'Todo' || i.status === 'In Progress').length, 0
        );

        const filteredList = apartments.filter(a => a.id.toLowerCase().includes(searchTerm.toLowerCase()));

        const getStatusBadgeClass = (status) => {
            switch(status) {
                case 'In Progress': return 'bg-amber-50 text-amber-700 border-amber-200';
                case 'Complete': return 'bg-emerald-50 text-emerald-700 border-emerald-200';
                default: return 'bg-slate-100 text-slate-600 border-slate-200';
            }
        };

        if (!isAuthenticated) {
            return (
                <div className="min-h-screen flex items-center justify-center p-4 bg-slate-900 relative overflow-hidden">
                    <div className="absolute inset-0 opacity-10 bg-[radial-gradient(#3b82f6_1px,transparent_1px)] [background-size:16px_16px]"></div>
                    <div className="w-full max-w-md bg-white rounded-[2.5rem] shadow-2xl p-8 md:p-10 text-center relative z-10 animate-in">
                        <div className="w-20 h-20 bg-indigo-50 text-indigo-600 rounded-3xl flex items-center justify-center mx-auto mb-6"><Icons.Layout size={40} /></div>
                        <h2 className="text-3xl font-black text-slate-800 mb-2">Apartment Manager</h2>
                        <p className="text-slate-400 font-bold text-sm mb-8">Sign in to access dashboard</p>
                        <button onClick={handleGoogleLogin} className="w-full flex items-center justify-center gap-4 bg-white border-2 border-slate-200 hover:border-slate-400 text-slate-700 font-black py-4 px-6 rounded-2xl transition-all shadow-sm">
                            <svg className="w-5 h-5" viewBox="0 0 24 24"><path fill="#EA4335" d="M12.24 10.285V14.4h6.887c-.275 1.565-1.88 4.604-6.887 4.604-4.33 0-7.866-3.577-7.866-8s3.536-8 7.866-8c2.46 0 4.105 1.025 5.047 1.926l3.227-3.11C18.436 2.064 15.62 1 12.24 1 6.033 1 12.24s5.033 11.24 11.24 11.24c6.478 0 10.793-4.537 10.793-10.986 0-.74-.08-1.3-.176-1.854H12.24z"/></svg>
                            Sign in with Google
                        </button>
                    </div>
                </div>
            );
        }

        return (
            <div className="min-h-screen flex flex-col">
                <header className="bg-slate-900 text-white p-4 sticky top-0 z-50 shadow-lg border-b border-slate-800">
                    <div className="max-w-7xl mx-auto flex justify-between items-center">
                        <div className="flex items-center gap-3 cursor-pointer" onClick={() => setSelectedId(null)}>
                            <div className="bg-indigo-600 p-2 rounded-xl text-white"><Icons.Layout size={22} /></div>
                            <h1 className="text-xl font-black tracking-tight">Apartment Manager</h1>
                        </div>
                        <div className="flex items-center gap-4">
                            <div className="relative w-48 sm:w-64">
                                <span className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"><Icons.Search size={16} /></span>
                                <input
                                    className="w-full bg-slate-800/80 border border-slate-700/80 rounded-xl py-2 pl-10 pr-4 outline-none text-sm text-slate-200 focus:border-indigo-500 transition-all"
                                    placeholder="Search Apartment..."
                                    value={searchTerm}
                                    onChange={e => setSearchTerm(e.target.value)}
                                />
                            </div>
                            <button onClick={handleLogout} className="bg-slate-800 hover:bg-rose-600/20 hover:text-rose-400 p-2.5 rounded-xl transition-all text-slate-400"><Icons.Lock size={18} /></button>
                        </div>
                    </div>
                </header>

                <div className="max-w-7xl mx-auto w-full p-4 lg:p-6 grid grid-cols-1 lg:grid-cols-12 gap-8 flex-1 items-start">

                    {/* SIDEBAR PANEL */}
                    <aside className="lg:col-span-3 flex flex-col gap-6 self-stretch justify-between">
                        <div className="space-y-6">
                            <button
                                onClick={() => setSelectedId(null)}
                                className={`w-full p-4 rounded-2xl font-black text-sm flex items-center gap-3 border-2 transition-all ${selectedId === null ? 'bg-indigo-600 text-white border-indigo-600 shadow-md' : 'bg-white border-transparent text-slate-700 hover:border-slate-200'}`}
                            >
                                <Icons.Layout size={18} /> Dashboard
                            </button>

                            <div className="border-t border-slate-200 pt-4">
                                <div className="flex justify-between items-center mb-3 px-1">
                                    <p className="text-[11px] font-black uppercase text-slate-400 tracking-wider">Apartments List</p>
                                </div>
                                <div className="flex flex-col gap-2 max-h-[60vh] overflow-y-auto pr-1 custom-scrollbar">
                                    {filteredList.map(apt => {
                                        const aptTotal = apt.items.reduce((sum, item) => sum + (Number(item.price) || 0), 0);
                                        const countTodo = apt.items.filter(t => t.status === 'Todo').length;
                                        const countInProg = apt.items.filter(t => t.status === 'In Progress').length;

                                        return (
                                            <button
                                                key={apt.id}
                                                onClick={() => setSelectedId(apt.id)}
                                                className={`w-full p-3 rounded-xl border transition-all text-sm flex flex-col gap-2 text-left ${selectedId === apt.id ? 'bg-slate-800 border-slate-800 text-white' : 'bg-white border-slate-100 text-slate-600 hover:border-slate-300'}`}
                                            >
                                                <div className="flex justify-between items-center w-full gap-2">
                                                    <span className="font-bold truncate">{apt.id}</span>
                                                    <div className="flex items-center gap-1.5 shrink-0">
                                                        <span className={`text-xs font-black px-2 py-0.5 rounded-md ${selectedId === apt.id ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600'}`}>${aptTotal}</span>

                                                        {apt.items.length === 0 && (
                                                            <span
                                                                onClick={(e) => deleteApartment(apt.id, e)}
                                                                className={`p-1 rounded-md transition-all ${selectedId === apt.id ? 'text-slate-400 hover:text-rose-400 hover:bg-rose-500/20' : 'text-slate-400 hover:text-rose-600 hover:bg-slate-100'}`}
                                                                title="Delete Empty Apartment"
                                                            >
                                                                <Icons.Trash size={13} />
                                                            </span>
                                                        )}
                                                    </div>
                                                </div>

                                                {(countTodo > 0 || countInProg > 0) && (
                                                    <div className="flex gap-2">
                                                        {countTodo > 0 && <span className={`text-[10px] px-1.5 py-0.5 rounded font-bold ${selectedId === apt.id ? 'bg-slate-600 text-slate-200' : 'bg-slate-200 text-slate-600'}`}>Todo: {countTodo}</span>}
                                                        {countInProg > 0 && <span className={`text-[10px] px-1.5 py-0.5 rounded font-bold ${selectedId === apt.id ? 'bg-amber-600/30 text-amber-300' : 'bg-amber-100 text-amber-700'}`}>In Prog: {countInProg}</span>}
                                                    </div>
                                                )}
                                            </button>
                                        );
                                    })}
                                </div>
                            </div>
                        </div>

                        {currentUser && (
                            <div className="bg-slate-900 text-white p-4 rounded-2xl flex items-center gap-3 shadow-inner border border-slate-800 mt-auto">
                                <img src={currentUser.avatar} alt="avatar" className="w-10 h-10 rounded-full object-cover border border-indigo-500/50" />
                                <div className="overflow-hidden">
                                    <p className="text-xs font-black text-slate-200 truncate">{currentUser.name}</p>
                                    <p className="text-[10px] text-slate-400 font-medium truncate">{currentUser.email}</p>
                                </div>
                            </div>
                        )}
                    </aside>

                    {/* MAIN CONTENT AREA */}
                    <main className="lg:col-span-9 bg-white rounded-[2rem] border border-slate-200 p-6 md:p-8 shadow-sm min-h-[500px] overflow-hidden">

                        {/* DASHBOARD VIEW */}
                        {selectedId === null ? (
                            <div className="animate-in space-y-8">
                                <div>
                                    <h2 className="text-3xl font-black text-slate-800 tracking-tight">Dashboard</h2>
                                    <p className="text-slate-400 font-bold text-sm mt-1">Overview of your apartment management</p>
                                </div>

                                {totalApartments === 0 ? (
                                    <div className="p-8 border-2 border-dashed border-slate-200 rounded-[2rem] text-center max-w-xl mx-auto py-12">
                                        <div className="w-16 h-16 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-4"><Icons.Home size={28}/></div>
                                        <h3 className="text-xl font-black text-slate-800 mb-1">No Apartments Found</h3>
                                        <p className="text-sm font-medium text-slate-400 mb-6">Start managing records by adding an apartment.</p>
                                        <form onSubmit={handleAddApartment} className="flex gap-2 max-w-md mx-auto">
                                            <input type="text" required className="flex-1 p-3.5 bg-slate-50 border-2 border-slate-200 rounded-xl outline-none focus:border-indigo-500 font-bold text-sm" placeholder="e.g., Apartment A1" value={newAptName} onChange={e => setNewAptName(e.target.value)} />
                                            <button type="submit" className="bg-indigo-600 hover:bg-indigo-700 text-white font-black px-6 rounded-xl transition-all">Add</button>
                                        </form>
                                    </div>
                                ) : (
                                    <div className="space-y-8">
                                        {/* STATS */}
                                        <div className="grid grid-cols-1 sm:grid-cols-3 gap-6">
                                            <div className="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex justify-between items-center">
                                                <div><p className="text-sm font-black text-slate-400 uppercase tracking-wider">Apartments</p><p className="text-3xl font-black text-slate-800 mt-1">{totalApartments}</p></div>
                                                <div className="p-3 bg-indigo-50 text-indigo-600 rounded-xl"><Icons.Home size={24}/></div>
                                            </div>
                                            <div className="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex justify-between items-center">
                                                <div><p className="text-sm font-black text-slate-400 uppercase tracking-wider">Active Tasks</p><p className="text-3xl font-black text-amber-600 mt-1">{totalActiveTasks}</p></div>
                                                <div className="p-3 bg-amber-50 text-amber-600 rounded-xl"><Icons.Wrench size={24}/></div>
                                            </div>
                                            <div className="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex justify-between items-center">
                                                <div><p className="text-sm font-black text-slate-400 uppercase tracking-wider">Total Expenses</p><p className="text-3xl font-black text-emerald-600 mt-1">${grandTotalExpenses.toLocaleString()}</p></div>
                                                <div className="p-3 bg-emerald-50 text-emerald-600 rounded-xl"><Icons.TrendingUp size={24}/></div>
                                            </div>
                                        </div>

                                        {/* ADD APARTMENT FORM */}
                                        <div className="bg-slate-50 p-5 rounded-2xl border border-slate-200 max-w-md">
                                            <h4 className="text-sm font-black text-slate-700 mb-2.5 uppercase tracking-wide flex items-center gap-1.5">
                                                <Icons.Plus size={16} className="text-indigo-600" /> Add New Apartment
                                            </h4>
                                            <form onSubmit={handleAddApartment} className="flex gap-2">
                                                <input
                                                    type="text"
                                                    required
                                                    className="flex-1 p-2.5 bg-white border border-slate-200 rounded-xl outline-none focus:border-indigo-500 font-bold text-sm"
                                                    placeholder="e.g., A3, B12"
                                                    value={newAptName}
                                                    onChange={e => setNewAptName(e.target.value)}
                                                />
                                                <button type="submit" className="bg-indigo-600 hover:bg-indigo-700 text-white font-black text-xs uppercase tracking-wider px-5 rounded-xl transition-all shadow-sm">Add</button>
                                            </form>
                                        </div>

                                        {/* APARTMENTS OVERVIEW GRID */}
                                        <div className="pt-4 border-t border-slate-100">
                                            <h3 className="font-black text-slate-800 text-lg mb-6 flex items-center gap-2">
                                                <Icons.Home size={20} className="text-indigo-600"/> Apartments Overview
                                            </h3>

                                            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                                                {filteredList.map(apt => {
                                                    const aptTotal = apt.items.reduce((sum, item) => sum + (Number(item.price) || 0), 0);
                                                    const countTodo = apt.items.filter(i => i.status === 'Todo').length;
                                                    const countInProg = apt.items.filter(i => i.status === 'In Progress').length;
                                                    const countComplete = apt.items.filter(i => i.status === 'Complete').length;

                                                    return (
                                                        <div
                                                            key={apt.id}
                                                            onClick={() => setSelectedId(apt.id)}
                                                            className="bg-slate-50 border border-slate-200 hover:border-indigo-400 p-5 rounded-2xl shadow-sm cursor-pointer transition-all flex flex-col justify-between gap-4 group"
                                                        >
                                                            <div className="flex justify-between items-start">
                                                                <h4 className="text-xl font-black text-slate-800 group-hover:text-indigo-600 transition-colors truncate pr-2">{apt.id}</h4>
                                                                <span className="text-lg font-black text-emerald-600 shrink-0">{aptTotal} $</span>
                                                            </div>

                                                            <div className="space-y-1 pt-2 border-t border-slate-200/60 text-xs font-bold">
                                                                <div className="flex justify-between text-amber-700 bg-amber-50/60 px-2.5 py-1.5 rounded-lg">
                                                                    <span>In Progress</span>
                                                                    <span className="font-black">{countInProg}</span>
                                                                </div>
                                                                <div className="flex justify-between text-slate-600 bg-slate-100 px-2.5 py-1.5 rounded-lg">
                                                                    <span>To Do</span>
                                                                    <span className="font-black">{countTodo}</span>
                                                                </div>
                                                                <div className="flex justify-between text-emerald-700 bg-emerald-50/60 px-2.5 py-1.5 rounded-lg">
                                                                    <span>Complete</span>
                                                                    <span className="font-black">{countComplete}</span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    );
                                                })}
                                            </div>
                                        </div>
                                    </div>
                                )}
                            </div>
                        ) : (
                            /* DETAILED APARTMENT VIEW */
                            <div className="animate-in space-y-6">
                                <div className="flex flex-col sm:flex-row justify-between sm:items-center gap-4 pb-4 border-b border-slate-100">
                                    <div className="flex items-center gap-3">
                                        <button onClick={() => setSelectedId(null)} className="p-2 hover:bg-slate-100 rounded-xl text-slate-400 hover:text-slate-600 transition-colors">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                                        </button>
                                        <h2 className="text-3xl font-black text-slate-800 tracking-tight">{selectedId} Profile</h2>
                                    </div>
                                    <div className="bg-emerald-50 text-emerald-700 px-4 py-2 rounded-xl font-black text-sm">
                                        Total: ${apartments.find(a => a.id === selectedId)?.items.reduce((sum, item) => sum + (Number(item.price) || 0), 0)}
                                    </div>
                                </div>

                                <div className="bg-slate-50 p-6 rounded-2xl border border-slate-100 space-y-4">
                                    <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                                        <div className="space-y-3">
                                            <input
                                                className="w-full p-3 bg-white border border-slate-200 rounded-xl outline-none focus:border-indigo-500 text-sm font-bold"
                                                placeholder="Item Fix / Actual Item (e.g., Fridge Repair)"
                                                value={form.title}
                                                onChange={e => setForm({...form, title: e.target.value})}
                                            />
                                            <div className="flex gap-2">
                                                <input
                                                    type="number"
                                                    className="flex-1 p-3 bg-white border border-slate-200 rounded-xl outline-none focus:border-indigo-500 text-sm font-black text-emerald-600"
                                                    placeholder="Price ($)"
                                                    value={form.price}
                                                    onChange={e => setForm({...form, price: e.target.value})}
                                                />
                                                <select
                                                    className="p-3 bg-white border border-slate-200 rounded-xl outline-none focus:border-indigo-500 text-xs font-bold text-slate-600"
                                                    value={form.status || 'Todo'}
                                                    onChange={e => setForm({...form, status: e.target.value})}
                                                >
                                                    <option value="Todo">Todo</option>
                                                    <option value="In Progress">In Progress</option>
                                                    <option value="Complete">Complete</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div className="grid grid-cols-2 gap-3">
                                            <div>
                                                <input id="prod-file" type="file" accept="image/*" className="hidden" onChange={e => handleFile(e, 'productImage')}/>
                                                <label htmlFor="prod-file" className="h-24 border-2 border-dashed border-slate-200 bg-white rounded-xl flex flex-col items-center justify-center cursor-pointer hover:bg-slate-100 relative overflow-hidden">
                                                    {form.productImage ? <img src={form.productImage} className="absolute inset-0 w-full h-full object-cover"/> : <div className="text-center"><Icons.Image size={20} className="mx-auto text-slate-300"/><span className="text-[10px] font-black text-slate-400 mt-1 block">PRODUCT</span></div>}
                                                </label>
                                            </div>
                                            <div>
                                                <input id="inv-file" type="file" accept="image/*" className="hidden" onChange={e => handleFile(e, 'invoiceImage')}/>
                                                <label htmlFor="inv-file" className="h-24 border-2 border-dashed border-slate-200 bg-white rounded-xl flex flex-col items-center justify-center cursor-pointer hover:bg-slate-100 relative overflow-hidden">
                                                    {form.invoiceImage ? <img src={form.invoiceImage} className="absolute inset-0 w-full h-full object-cover"/> : <div className="text-center"><Icons.File size={20} className="mx-auto text-slate-300"/><span className="text-[10px] font-black text-slate-400 mt-1 block">INVOICE</span></div>}
                                                </label>
                                            </div>
                                        </div>
                                        <div className="flex flex-col gap-3">
                                            <textarea className="flex-1 p-3 bg-white border border-slate-200 rounded-xl outline-none focus:border-indigo-500 text-xs resize-none" placeholder="Notes / Descriptions..." value={form.notes} onChange={e => setForm({...form, notes: e.target.value})}/>
                                            <button onClick={saveItem} className="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-3 rounded-xl uppercase tracking-wider text-xs shadow-md transition-colors">Save</button>
                                        </div>
                                    </div>
                                </div>

                                <div className="space-y-3 pt-4">
                                    {apartments.find(a => a.id === selectedId)?.items.map(item => (
                                        <div key={item.id} className="border border-slate-100 bg-slate-50/50 p-4 rounded-2xl flex flex-col sm:flex-row items-center gap-4">
                                            <div className="flex gap-2 shrink-0">
                                                {item.productImage ? <img src={item.productImage} className="w-14 h-14 rounded-lg object-cover border" /> : <div className="w-14 h-14 bg-white rounded-lg border border-dashed flex items-center justify-center text-slate-300"><Icons.Image size={16}/></div>}
                                                {item.invoiceImage ? <img src={item.invoiceImage} className="w-14 h-14 rounded-lg object-cover border" /> : <div className="w-14 h-14 bg-white rounded-lg border border-dashed flex items-center justify-center text-slate-300"><Icons.File size={16}/></div>}
                                            </div>
                                            <div className="flex-1 min-w-0 text-center sm:text-left">
                                                <div className="flex flex-col sm:flex-row sm:items-center gap-2">
                                                    <h4 className="font-black text-slate-800 text-sm truncate">{item.title}</h4>
                                                    <select
                                                        value={item.status || 'Todo'}
                                                        onChange={(e) => updateItemStatus(item.id, e.target.value)}
                                                        className={`text-[10px] font-black uppercase px-2 py-0.5 rounded-md border outline-none cursor-pointer transition-colors ${getStatusBadgeClass(item.status || 'Todo')}`}
                                                    >
                                                        <option value="Todo">Todo</option>
                                                        <option value="In Progress">In Progress</option>
                                                        <option value="Complete">Complete</option>
                                                    </select>
                                                </div>
                                                <p className="text-[10px] font-bold text-slate-400 mt-0.5">{item.date}</p>
                                                {item.notes && <p className="text-xs text-slate-500 mt-1 bg-white p-2 rounded-lg border border-slate-100 inline-block">{item.notes}</p>}
                                            </div>
                                            <div className="flex items-center gap-3">
                                                <span className="text-lg font-black text-slate-800">${item.price}</span>
                                                <button onClick={() => deleteItem(item.id)} className="p-2 text-slate-400 hover:text-rose-500 rounded-lg hover:bg-white transition-colors"><Icons.Trash size={16}/></button>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}
                    </main>
                </div>
            </div>
        );
    };

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render((<App />));
</script>
</body>
</html>





















